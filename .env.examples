# Logging
LOG_LEVEL=DEBUG
LOG_FILENAME="research_knowledge.log"

# Database
DATABASE_PROVIDER=sqlite

# SQLite
SQLITE_DATABASE_PATH=data/research.db
SQLITE_SCHEMA_FILENAME="sqlite_schema.sql"

# Supabase PostgreSQL
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DATABASE=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSLMODE=require